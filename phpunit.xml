<?xml version="1.0" encoding="UTF-8"?>

<phpunit
	bootstrap="vendor/autoload.php"
	backupGlobals="false"
	colors="true"
	cacheResult="false"
	processIsolation="false"
	stopOnFailure="false"
>
	<testsuites>
		<testsuite name="Properties Test suite">
			<directory>tests/</directory>
		</testsuite>
	</testsuites>

	<source>
		<include>
			<directory suffix=".php">src/</directory>
		</include>
	</source>
</phpunit>
